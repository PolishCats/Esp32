# =====================================================
# ESP32 LDR Monitor - Environment Variables
# =====================================================

# Server
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=esp32_ldr_monitor

# JWT
JWT_SECRET=desarrollo_secreto_cambiar_en_produccion_32caracteres_minimo
JWT_EXPIRES_IN=24h

# Session
SESSION_SECRET=otro_secreto_largo_para_sesiones_desarrollo

# Email (Nodemailer - usar Gmail o SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu_email@gmail.com
SMTP_PASS=contraseña_app

# Data retention (days)
DATA_RETENTION_DAYS=30

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
